{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"next,worker\" --prefix-colors \"cyan,yellow\" \"next dev --turbopack\" \"node --env-file=.env.queue --env-file-if-exists=.env.local --import tsx/esm ./lib/queue/worker.ts\"",
    "dev:worker": "node --env-file=.env.queue --env-file-if-exists=.env.local --import tsx/esm ./lib/queue/worker.ts",
    "build": "next build",
    "start": "next start",
    "start:worker": "node --env-file=.env.queue --env-file-if-exists=.env.local --import tsx/esm ./lib/queue/worker.ts",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sentry/nextjs": "^10.45.0",
    "@workspace/ui": "*",
    "bullmq": "^5.19.0",
    "ioredis": "^5.6.0",
    "lucide-react": "^1.6.0",
    "nanoid": "^5.0.7",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^2.1.9",
    "@workspace/eslint-config": "*",
    "@workspace/typescript-config": "*",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "tsx": "^4.15.2",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.8"
  }
}
